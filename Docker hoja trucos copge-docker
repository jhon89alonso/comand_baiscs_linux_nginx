docker compose run --rm node npm install	Instala las librerías de Node (Vue, Axios, Echo).
docker compose run --rm node npm run dev	Compila los assets de Vue para que la interfaz se vea bien.
docker compose run --rm node npm run watch	Se queda escuchando cambios; si editas un .vue, se compila solo.

sudo chown -R $USER:$USER .	Le devuelve el poder a tu usuario de Linux para que puedas hacer git pull o stash.
docker compose exec app chown -R www-data:www-data storage bootstrap/cache	Le da poder al servidor web para escribir logs y caché (quita el error 500).
git stash	"Congela" tus cambios actuales (como el Dockerfile) para poder cambiar de rama.
git stash pop	"Descongela" tus cambios después de un pull.
git config --global core.autocrlf input	Evita problemas de saltos de línea entre Windows y Linux.


